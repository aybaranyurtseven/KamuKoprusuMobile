rules_version = '2';

// Kamu Köprüsü — Firebase Storage güvenlik kuralları
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil avatarları: avatars/{uid}.jpg
    // Herkes okuyabilir; oturum açmış kullanıcı yükleyebilir (maks. 5 MB).
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isSignedIn();
    }

    // Şikayet medyası: complaints/{complaintId}/{dosya}
    // Herkes okuyabilir; oturum açmış kullanıcı yükleyebilir (maks. 10 MB).
    match /complaints/{complaintId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Diğer tüm yollar varsayılan olarak kapalı.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
